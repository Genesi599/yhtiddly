{
  "name": "tw-sync-desktop",
  "version": "0.1.0",
  "description": "TiddlyWiki desktop sync app with local SQLite cache and background remote sync",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "pack:win": "electron-packager . TWSync --platform=win32 --arch=x64 --out=dist --overwrite --icon=ui/app-icon.ico --app-copyright=\"yh109\" --ignore=\"^/dist\" --ignore=\"^\\.git\" --ignore=\"^/\\.\" --ignore=\"README\" --prune=true && node scripts/set-icon.js",
    "pack:mac": "electron-packager . TWSync --platform=darwin --arch=x64 --out=dist --overwrite --icon=ui/tray-icon.png --ignore=\"^/dist\" --ignore=\"^\\.git\" --prune=true",
    "pack:linux": "electron-packager . TWSync --platform=linux --arch=x64 --out=dist --overwrite --ignore=\"^/dist\" --ignore=\"^\\.git\" --prune=true"
  },
  "author": "yh109",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "express": "^4.21.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-packager": "^17.1.2",
    "@electron/rebuild": "^3.6.0"
  }
}
